NODE_ENV=development
PORT=3001
DATABASE_URL=mysql://finance:finance@localhost:3306/finance_bot
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
# Choose one OCR auth mode:
# 1) API key mode:
# GCP_VISION_API_KEY=your_google_cloud_vision_api_key
# 2) Service account JSON mode:
GCP_VISION_CREDENTIALS_PATH=./your-service-account.json
GCP_VISION_API_KEY=
REPORTING_SERVICE_URL=http://localhost:8000
PAYMENT_WEB_BASE_URL=http://localhost:3000
ADMIN_API_TOKEN=change_this_admin_api_token
BOT_INTERNAL_TOKEN=change_this_bot_internal_token
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
BOT_HEARTBEAT_STALE_SECONDS=120
EMERGENCY_FUND_STABLE_MULTIPLIER=6
EMERGENCY_FUND_UNSTABLE_MULTIPLIER=9
FINANCIAL_FREEDOM_EXPENSE_MULTIPLIER=25
