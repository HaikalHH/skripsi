generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  SAVING
}

enum TransactionSource {
  TEXT
  OCR
}

enum MessageType {
  TEXT
  IMAGE
}

enum AnalysisType {
  INTENT
  EXTRACTION
  INSIGHT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  INACTIVE
}

enum RegistrationStatus {
  PENDING
  COMPLETED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OnboardingStep {
  WAIT_REGISTER
  VERIFY_PHONE
  ASK_PRIMARY_GOAL
  ASK_EMPLOYMENT_TYPES
  ASK_HAS_ACTIVE_INCOME
  ASK_ACTIVE_INCOME
  ASK_SALARY_DATE
  ASK_HAS_PASSIVE_INCOME
  ASK_PASSIVE_INCOME
  ASK_ESTIMATED_MONTHLY_INCOME
  ASK_BUDGET_MODE
  ASK_MANUAL_EXPENSE_BREAKDOWN
  ASK_GUIDED_EXPENSE_FOOD
  ASK_GUIDED_EXPENSE_TRANSPORT
  ASK_GUIDED_EXPENSE_BILLS
  ASK_GUIDED_EXPENSE_ENTERTAINMENT
  ASK_GUIDED_EXPENSE_OTHERS
  ASK_GOAL_SELECTION
  ASK_GOAL_CUSTOM_NAME
  ASK_GOAL_TARGET_AMOUNT
  ASK_GOAL_TARGET_DATE
  ASK_GOAL_ALLOCATION_MODE
  ASK_GOAL_PRIORITY_FOCUS
  ASK_GOAL_EXPENSE_STRATEGY
  ASK_GOAL_EXPENSE_TOTAL
  ASK_GOAL_FINANCIAL_FREEDOM_AGE
  ASK_GOAL_ADD_MORE
  ASK_ASSET_SELECTION
  ASK_ASSET_SAVINGS_NAME
  ASK_ASSET_SAVINGS_BALANCE
  ASK_ASSET_GOLD_TYPE
  ASK_ASSET_GOLD_BRAND
  ASK_ASSET_GOLD_NAME
  ASK_ASSET_GOLD_GRAMS
  ASK_ASSET_GOLD_KARAT
  ASK_ASSET_GOLD_PLATFORM
  ASK_ASSET_STOCK_SYMBOL
  ASK_ASSET_STOCK_LOTS
  ASK_ASSET_CRYPTO_SYMBOL
  ASK_ASSET_CRYPTO_QUANTITY
  ASK_ASSET_MUTUAL_FUND_SYMBOL
  ASK_ASSET_MUTUAL_FUND_UNITS
  ASK_ASSET_PROPERTY_NAME
  ASK_ASSET_PROPERTY_ESTIMATED_VALUE
  ASK_ASSET_NAME
  ASK_ASSET_ESTIMATED_VALUE
  ASK_ASSET_ADD_MORE
  ASK_PERSONALIZATION_CHOICE
  SHOW_ANALYSIS
  COMPLETED
}

enum PaymentSessionStatus {
  PENDING
  PAID
  EXPIRED
}

enum PaymentProvider {
  DUMMY
  AIRWALLEX
}

enum OutboundMessageStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum PortfolioAssetType {
  GOLD
  STOCK
  MUTUAL_FUND
  CRYPTO
  DEPOSIT
  PROPERTY
  BUSINESS
  OTHER
}

enum PortfolioTradeSide {
  BUY
  SELL
}

enum PrimaryGoal {
  MANAGE_EXPENSES
  SAVE_DISCIPLINED
  TRACK_INVESTMENTS
  FINANCIAL_FREEDOM
  ALL_OF_THE_ABOVE
}

enum EmploymentType {
  STUDENT
  EMPLOYEE
  FREELANCER
  ENTREPRENEUR
  OTHER
  MIXED
}

enum IncomeStability {
  STABLE
  UNSTABLE
  MIXED
}

enum BudgetMode {
  MANUAL_PLAN
  GUIDED_PLAN
  AUTO_FROM_TRANSACTIONS
}

enum ExpensePlanSource {
  MANUAL_USER_PLAN
  GUIDED_ONBOARDING_PLAN
  AUTO_GENERATED_LATER
}

enum FinancialGoalType {
  EMERGENCY_FUND
  HOUSE
  VEHICLE
  VACATION
  FINANCIAL_FREEDOM
  CUSTOM
}

enum GoalCalculationType {
  MANUAL
  AUTO_FROM_EXPENSE
  FORMULA_BASED
}

enum GoalExecutionMode {
  SEQUENTIAL
  PARALLEL
}

enum FinancialGoalStatus {
  ACTIVE
  PENDING_CALCULATION
  COMPLETED
  ARCHIVED
}

enum AssetType {
  CASH
  SAVINGS
  GOLD
  STOCK
  CRYPTO
  MUTUAL_FUND
  PROPERTY
  OTHER
}

enum OnboardingQuestionKey {
  START_CONFIRMATION
  PHONE_VERIFICATION
  PRIMARY_GOAL
  EMPLOYMENT_TYPES
  HAS_ACTIVE_INCOME
  ACTIVE_INCOME_MONTHLY
  SALARY_DATE
  HAS_PASSIVE_INCOME
  PASSIVE_INCOME_MONTHLY
  ESTIMATED_MONTHLY_INCOME
  BUDGET_MODE
  MANUAL_EXPENSE_BREAKDOWN
  GUIDED_EXPENSE_FOOD
  GUIDED_EXPENSE_TRANSPORT
  GUIDED_EXPENSE_BILLS
  GUIDED_EXPENSE_ENTERTAINMENT
  GUIDED_EXPENSE_OTHERS
  GOAL_SELECTION
  GOAL_CUSTOM_NAME
  GOAL_TARGET_AMOUNT
  GOAL_TARGET_DATE
  GOAL_ALLOCATION_MODE
  GOAL_PRIORITY_FOCUS
  GOAL_EXPENSE_STRATEGY
  GOAL_EXPENSE_TOTAL
  GOAL_FINANCIAL_FREEDOM_AGE
  GOAL_ADD_MORE
  ASSET_SELECTION
  ASSET_SAVINGS_NAME
  ASSET_SAVINGS_BALANCE
  ASSET_GOLD_TYPE
  ASSET_GOLD_BRAND
  ASSET_GOLD_NAME
  ASSET_GOLD_GRAMS
  ASSET_GOLD_KARAT
  ASSET_GOLD_PLATFORM
  ASSET_STOCK_SYMBOL
  ASSET_STOCK_LOTS
  ASSET_CRYPTO_SYMBOL
  ASSET_CRYPTO_QUANTITY
  ASSET_MUTUAL_FUND_SYMBOL
  ASSET_MUTUAL_FUND_UNITS
  ASSET_PROPERTY_NAME
  ASSET_PROPERTY_ESTIMATED_VALUE
  ASSET_NAME
  ASSET_ESTIMATED_VALUE
  ASSET_ADD_MORE
  PERSONALIZATION_CHOICE
}

model User {
  id                        String                  @id @default(cuid())
  waNumber                  String                  @unique
  name                      String?
  currency                  String                  @default("IDR")
  monthlyBudget             Decimal?                @db.Decimal(12, 2)
  registrationStatus        RegistrationStatus      @default(PENDING)
  onboardingStatus          OnboardingStatus        @default(NOT_STARTED)
  onboardingStep            OnboardingStep          @default(WAIT_REGISTER)
  primaryGoal               PrimaryGoal?
  employmentType            EmploymentType?
  incomeStability           IncomeStability?
  hasPassiveIncome          Boolean?
  salaryDate                Int?
  targetFinancialFreedomAge Int?
  goalExecutionMode         GoalExecutionMode?
  priorityGoalType          FinancialGoalType?
  budgetMode                BudgetMode?
  hasAssets                 Boolean?
  analysisReady             Boolean                 @default(false)
  onboardingCompletedAt     DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  transactions              Transaction[]
  messageLogs               MessageLog[]
  aiAnalysisLogs            AIAnalysisLog[]
  budgets                   Budget[]
  savingsGoal               SavingsGoal?
  reminderPreference        ReminderPreference?
  subscriptions             Subscription[]
  paymentSessions           PaymentSession[]
  paymentProviderEvents     PaymentProviderEvent[]
  outboundMessages          OutboundMessage[]
  portfolioAssets           PortfolioAsset[]
  portfolioTrades           PortfolioTrade[]
  financialFreedom          FinancialFreedomProfile?
  financialProfile          FinancialProfile?
  expensePlans              ExpensePlan[]
  financialGoals            FinancialGoal[]
  goalContributions         GoalContribution[]
  assets                    Asset[]
  onboardingSessions        OnboardingSession[]
  intentObservations        IntentObservation[]
  reminderEvents            ReminderEvent[]
}

model Transaction {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       TransactionType
  amount     Decimal           @db.Decimal(12, 2)
  category   String
  detailTag  String?
  merchant   String?
  note       String?
  occurredAt DateTime
  source     TransactionSource
  rawText    String?
  createdAt  DateTime          @default(now())

  @@index([userId, occurredAt])
  @@index([userId, type])
}

model MessageLog {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageType         MessageType
  contentOrCaption    String
  mediaUrlOrLocalPath String?
  sentAt              DateTime        @default(now())
  aiAnalysisLogs      AIAnalysisLog[]

  @@index([userId, sentAt])
}

model AIAnalysisLog {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId    String?
  message      MessageLog?  @relation(fields: [messageId], references: [id], onDelete: SetNull)
  analysisType AnalysisType
  payloadJson  Json
  createdAt    DateTime     @default(now())

  @@index([userId, createdAt])
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     String
  monthlyLimit Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, category])
}

model SavingsGoal {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetAmount    Decimal  @db.Decimal(12, 2)
  currentProgress Decimal  @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                 SubscriptionStatus @default(TRIAL)
  provider               PaymentProvider    @default(DUMMY)
  providerSubscriptionId String?            @unique
  providerCustomerId     String?
  providerPriceId        String?
  providerStatus         String?
  currentPeriodStartAt   DateTime?
  currentPeriodEndAt     DateTime?
  cancelAt               DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([userId, status])
  @@index([userId, provider, createdAt])
}

model ReminderPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetEnabled    Boolean  @default(true)
  weeklyEnabled    Boolean  @default(true)
  weeklyReviewEnabled  Boolean  @default(true)
  recurringEnabled Boolean  @default(true)
  cashflowEnabled  Boolean  @default(true)
  goalEnabled      Boolean  @default(true)
  monthlyClosingEnabled Boolean @default(true)
  quietHoursStart  Int?
  quietHoursEnd    Int?
  minIntervalHours Int      @default(24)
  maxPerDay        Int      @default(3)
  snoozedUntil     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PaymentSession {
  id                     String               @id @default(cuid())
  userId                 String
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  token                  String               @unique
  amount                 Decimal              @db.Decimal(12, 2)
  currency               String               @default("IDR")
  provider               PaymentProvider      @default(DUMMY)
  status                 PaymentSessionStatus @default(PENDING)
  customerEmail          String?
  providerCheckoutId     String?              @unique
  providerSubscriptionId String?
  providerCustomerId     String?
  providerStatus         String?
  checkoutUrl            String?              @db.Text
  checkoutExpiresAt      DateTime?
  paidAt                 DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([userId, status])
  @@index([userId, provider, status])
  @@index([providerSubscriptionId])
}

model PaymentProviderEvent {
  id              String          @id @default(cuid())
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider        PaymentProvider
  providerEventId String
  eventType       String
  payloadJson     Json
  processedAt     DateTime        @default(now())
  createdAt       DateTime        @default(now())

  @@unique([provider, providerEventId])
  @@index([provider, eventType, createdAt])
  @@index([userId, createdAt])
}

model OutboundMessage {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  waNumber     String
  messageText  String
  status       OutboundMessageStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model PortfolioAsset {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType       PortfolioAssetType
  symbol          String
  displayName     String
  quantity        Decimal            @db.Decimal(24, 8)
  unit            String
  averageBuyPrice Decimal            @db.Decimal(18, 2)
  currency        String             @default("IDR")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, assetType, symbol])
  @@index([userId, assetType])
}

model PortfolioTrade {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType    PortfolioAssetType
  side         PortfolioTradeSide
  symbol       String
  displayName  String
  quantity     Decimal            @db.Decimal(24, 8)
  unit         String
  pricePerUnit Decimal            @db.Decimal(18, 2)
  totalAmount  Decimal            @db.Decimal(18, 2)
  realizedPnL  Decimal?           @db.Decimal(18, 2)
  currency     String             @default("IDR")
  occurredAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())

  @@index([userId, occurredAt])
  @@index([userId, symbol, occurredAt])
  @@index([userId, side, occurredAt])
}

model FinancialFreedomProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled            Boolean  @default(false)
  monthlyExpense     Decimal  @default(0) @db.Decimal(12, 2)
  targetYears        Int      @default(15)
  safeWithdrawalRate Decimal  @default(0.04) @db.Decimal(5, 4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FinancialProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeIncomeMonthly    BigInt?
  passiveIncomeMonthly   BigInt?
  estimatedMonthlyIncome BigInt?
  monthlyIncomeTotal     BigInt?
  monthlyExpenseTotal    BigInt?
  potentialMonthlySaving BigInt?
  savingRate             Decimal? @db.Decimal(7, 2)
  emergencyFundTarget    BigInt?
  financialFreedomTarget BigInt?
  annualExpense          BigInt?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ExpensePlan {
  id                  String            @id @default(cuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              ExpensePlanSource
  totalMonthlyExpense BigInt
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  items               ExpensePlanItem[]

  @@index([userId, isActive])
}

model ExpensePlanItem {
  id            String      @id @default(cuid())
  expensePlanId String
  expensePlan   ExpensePlan @relation(fields: [expensePlanId], references: [id], onDelete: Cascade)
  categoryKey   String
  amount        BigInt
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([expensePlanId, categoryKey])
}

model FinancialGoal {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalType              FinancialGoalType
  goalName              String
  targetAmount          BigInt?
  targetAge             Int?
  targetMonth           Int?
  targetYear            Int?
  calculationType       GoalCalculationType
  status                FinancialGoalStatus @default(ACTIVE)
  priorityOrder         Int                 @default(999)
  estimatedMonthsToGoal Decimal?            @db.Decimal(10, 2)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  contributions         GoalContribution[]

  @@index([userId, status])
  @@index([userId, goalType])
  @@index([userId, priorityOrder])
}

model GoalContribution {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId     String
  goal       FinancialGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount     BigInt
  note       String?
  occurredAt DateTime      @default(now())
  createdAt  DateTime      @default(now())

  @@index([userId, occurredAt])
  @@index([goalId, occurredAt])
}

model Asset {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType      AssetType
  assetName      String
  quantity       Decimal?  @db.Decimal(24, 8)
  unit           String?
  unitPrice      BigInt?
  estimatedValue BigInt?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, assetType])
}

model OnboardingSession {
  id                   String                @id @default(cuid())
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepKey              OnboardingStep
  questionKey          OnboardingQuestionKey
  rawAnswerJson        Json
  normalizedAnswerJson Json?
  isCompleted          Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, stepKey])
  @@index([userId, questionKey])
}

model SystemHeartbeat {
  id          String   @id @default(cuid())
  serviceName String   @unique
  lastSeenAt  DateTime @default(now())
}

model IntentObservation {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId            String?
  rawText              String
  effectiveText        String
  commandKind          String
  topModule            String?
  moduleOrderJson      Json?
  resolutionKind       String
  resolutionSource     String?
  semanticNormalizedText String?
  handledBy            String
  fallbackStage        String?
  ambiguityFlag        Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([handledBy, createdAt])
  @@index([ambiguityFlag, createdAt])
}

model ReminderEvent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderType String
  marker       String
  messageText  String
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId, sentAt])
  @@index([userId, reminderType, sentAt])
  @@index([userId, marker, sentAt])
}
